APP_NAME="PHP Secure System"
APP_URL="https://localhost"
APP_ENV="production"
APP_DEBUG=0

DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_NAME="secure_db"
DB_USER="secure_user"
DB_PASS="strong_password_here"
DB_CHARSET="utf8mb4"

SESSION_NAME="secure_session"
SESSION_LIFETIME=7200
SESSION_SECURE=1
SESSION_HTTPONLY=1
SESSION_SAMESITE="Strict"

BCRYPT_COST=12

TWO_FACTOR_ISSUER="PHPSecure"

CAPTCHA_ENABLED=0
CAPTCHA_SITE_KEY="your_site_key"
CAPTCHA_SECRET_KEY="your_secret_key"

RATE_LIMIT_LOGIN=5
RATE_LIMIT_REGISTER=3
RATE_LIMIT_TIME=300

MAIL_HOST="smtp.gmail.com"
MAIL_PORT=587
MAIL_USERNAME="your-email@gmail.com"
MAIL_PASSWORD="your-app-password"
MAIL_ENCRYPTION="tls"
MAIL_FROM_ADDRESS="noreply@yoursite.com"
MAIL_FROM_NAME="PHP Secure System"

LOG_PATH="/logs/security.log"
LOG_LEVEL="error"
